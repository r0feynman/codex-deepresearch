def run_synthesize(args: argparse.Namespace) -> int:
    try:
        result = synthesize_report(
            run=args.run,
            runs_dir=resolve_repo_path(args.runs_dir),
        )
    except (ReportGenerationError, SearchHandoffError, OSError) as exc:
        trace_cli_failure(
            args,
            stage="synthesize",
            agent_role="report_synthesis_agent",
            exc=exc,
        )
        print(f"ERROR: {exc}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    if result["status"] not in {"completed", "skipped"}:
        return 2
    return 0


def run_run_status(args: argparse.Namespace) -> int:
    try:
        run_dir = resolve_run_dir(args.run, runs_dir=resolve_repo_path(args.runs_dir))
        result = inspect_run_state(run_dir)
    except RunStepStateError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    except SearchHandoffError as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    return 0


def run_plan_parallel(args: argparse.Namespace) -> int:
    try:
        result = plan_research_tasks(
            run=args.run,
            runs_dir=resolve_repo_path(args.runs_dir),
            min_tasks=args.min_tasks,
            max_tasks=args.max_tasks,
            confirm_exhaustive=args.confirm_exhaustive,
            max_cost_usd=args.max_cost_usd,
        )
    except (ParallelOrchestrationError, SearchHandoffError, OSError) as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    return 0


def run_orchestrate_parallel(args: argparse.Namespace) -> int:
    try:
        result = run_parallel_orchestration(
            run=args.run,
            runs_dir=resolve_repo_path(args.runs_dir),
            adapter_name=args.adapter,
            min_tasks=args.min_tasks,
            max_tasks=args.max_tasks,
            retry_failed=args.retry_failed,
            allow_degraded=not args.no_degrade,
            confirm_exhaustive=args.confirm_exhaustive,
            max_cost_usd=args.max_cost_usd,
        )
    except (AdapterUnavailable, ParallelOrchestrationError, SearchHandoffError, OSError) as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    if result.get("ok") is False:
        return 2
    validation = result.get("merge", {}).get("validation")
    if isinstance(validation, dict) and validation.get("valid") is False:
        return 2
    return 0


def run_mvp_smoke_command(args: argparse.Namespace) -> int:
    try:
        result = run_mvp_smoke(
            runs_dir=resolve_repo_path(args.runs_dir),
            suite_id=args.suite_id,
            invoke=args.invoke,
            clean=args.clean,
            skip_codex_cli_install_check=args.skip_codex_cli_install_check,
        )
    except (MvpSmokeError, OSError, json.JSONDecodeError) as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        results_path = getattr(exc, "results_path", None)
        if results_path:
            print(f"Results: {results_path}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    return 0 if result["status"] == "passed" else 2


def run_fresh_session_e2e_command(args: argparse.Namespace) -> int:
    try:
        result = run_fresh_session_e2e(
            runs_dir=resolve_repo_path(args.runs_dir),
            suite_id=args.suite_id,
            invocation=args.invoke,
            clean=args.clean,
            real_codex_exec=args.real_codex_exec,
            runner_path=Path(__file__).resolve(),
            scenario_timeout_seconds=args.scenario_timeout_seconds,
        )
    except (FreshSessionE2EError, OSError, json.JSONDecodeError) as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        results_path = getattr(exc, "results_path", None)
        if results_path:
            print(f"Results: {results_path}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    return 0 if result["status"] == "passed" else 2


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="codex-deepresearch",
        description="Developer runner for the Codex DeepResearch plugin.",
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    smoke = subparsers.add_parser(
        "smoke",
        help="Validate the plugin scaffold and start a smoke run directory.",
    )
    smoke.add_argument(
        "--install",
        action="store_true",
        help="Also verify that local install/update prerequisites are available.",
    )
    smoke.add_argument(
        "--invoke",
        default="$deep-research: smoke test",
        help="Skill invocation text recorded in the smoke run status.",
    )
    smoke.add_argument(
        "--runs-dir",
        default="research-runs",
        help="Directory for smoke run artifacts, relative to the repo root by default.",
    )
    smoke.set_defaults(func=run_smoke)

    mvp_smoke = subparsers.add_parser(
        "mvp-smoke",
        help="Run the deterministic no-network MVP release-gate smoke suite.",
    )
    mvp_smoke.add_argument(
        "--invoke",
        default=DEFAULT_INVOKE,
        help="Skill invocation text recorded for the text-only invocation smoke.",
    )
    mvp_smoke.add_argument(
        "--runs-dir",
        default="research-runs",
        help="Directory for MVP smoke artifacts, relative to the repo root by default.",
    )
    mvp_smoke.add_argument(
        "--suite-id",
        default="mvp-smoke",
        help="Subdirectory name under --runs-dir for this smoke suite.",
    )
    mvp_smoke.add_argument(
        "--clean",
        action="store_true",
        help="Remove an existing suite directory before writing new artifacts.",
    )
    mvp_smoke.add_argument(
        "--skip-codex-cli-install-check",
        action="store_true",
        help=(
            "Skip the Codex CLI install/update capability check. The suite records "
            "the skip and does not mark plugin install/update smoke as passed."
        ),
    )
    mvp_smoke.set_defaults(func=run_mvp_smoke_command)

    fresh_session = subparsers.add_parser(
        "fresh-session-e2e",
        help="Run the scripted fresh-session $deep-research artifact handoff gate.",
    )
    fresh_session.add_argument(
        "--invoke",
        default=DEFAULT_FRESH_SESSION_INVOKE,
        help="Text-heavy $deep-research invocation captured in the scripted transcript.",
    )
    fresh_session.add_argument(
        "--runs-dir",
        default="research-runs",
        help="Directory for fresh-session gate artifacts, relative to the repo root by default.",
    )
    fresh_session.add_argument(
        "--suite-id",
        default="fresh-session-e2e",
        help="Subdirectory name under --runs-dir for this gate.",
    )
    fresh_session.add_argument(
        "--clean",
        action="store_true",
        help="Remove an existing suite directory before writing new artifacts.",
    )
    fresh_session.add_argument(
        "--real-codex-exec",
        default="skip",
        choices=("auto", "require", "skip"),
        help=(
            "How to handle the real codex-exec scenario: skip records a public-safe "
            "blocked diagnostic, auto attempts it when "
            "Codex CLI is available, require fails unless real execution is available, "
            "and every launched scenario is bounded by --scenario-timeout-seconds."
        ),
    )

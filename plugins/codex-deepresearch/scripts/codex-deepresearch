    ingest_manual.add_argument(
        "--vlm-provider",
        help="VLM provider metadata for new manual runs.",
    )
    ingest_manual.add_argument(
        "--budget",
        "--budget-preset",
        dest="budget",
        default="standard",
        help="Budget preset for new manual runs: quick, standard, deep, or exhaustive.",

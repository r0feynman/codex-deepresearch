    acquire_visual = subparsers.add_parser(
        "acquire-visual",
        help="Collect deterministic local/test visual candidates for visual routes.",
    )
    acquire_visual.add_argument(
        "--run",
        required=True,
        help="Run id under --runs-dir, or a direct path to a run directory.",

        print(f"ERROR: {exc}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    validation = result.get("validation")
    if result["status"] == "failed_validation":
        return 2
    if isinstance(validation, dict) and validation.get("valid") is False:
        return 2
    return 0


def run_ingest_vision(args: argparse.Namespace) -> int:
    try:
        result = ingest_vision_observations(
            run=args.run,
            runs_dir=resolve_repo_path(args.runs_dir),
            provider=args.provider,
            observations=args.observations,
            provider_mode=args.provider_mode,
            allow_real_vlm=args.allow_real_vlm,
        )
    except (VisionAdapterError, SearchHandoffError, OSError) as exc:
        trace_cli_failure(
            args,
            stage="ingest_vision",
            agent_role="vision_adapter",
            exc=exc,
        )
        print(f"ERROR: {exc}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    if result["status"] in {"failed_normalization", "failed_validation"}:
        return 2
    if result["status"] == "blocked_missing_vlm_provider":
        return 2
    validation = result.get("validation")
    if isinstance(validation, dict) and validation.get("valid") is False:
        return 2
    return 0


def run_acquire_visual(args: argparse.Namespace) -> int:
    try:
        providers = normalize_acquire_visual_providers(args.provider)
        if PAGE_IMAGE_EXTRACTOR_PROVIDER in providers:
            if providers == (PAGE_IMAGE_EXTRACTOR_PROVIDER,):
                result = extract_and_fetch_page_images(
                    run=args.run,
                    runs_dir=resolve_repo_path(args.runs_dir),
                    max_image_bytes=args.max_image_bytes,
                    max_fetches=args.max_fetches,
                    provider_mode="real",
                )
            else:
                result = acquire_visual_candidates(
                    run=args.run,
                    runs_dir=resolve_repo_path(args.runs_dir),
                    providers=args.provider,
                    screenshot_modes=args.screenshot_mode,
                    max_image_bytes=args.max_image_bytes,
                    max_pdf_bytes=args.max_pdf_bytes,
                    max_fetches=args.max_fetches,
                )
        else:
            result = acquire_visual_candidates(
                run=args.run,
                runs_dir=resolve_repo_path(args.runs_dir),
                providers=args.provider,
                screenshot_modes=args.screenshot_mode,
                max_image_bytes=args.max_image_bytes,
                max_pdf_bytes=args.max_pdf_bytes,
            )
    except (
        PageImageExtractionError,
        VisualAcquisitionError,
        SearchHandoffError,
        OSError,
    ) as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    if result.get("status") == "blocked_missing_visual_provider":
        return 2
    validation = result.get("validation")
    if isinstance(validation, dict) and validation.get("valid") is False:
        return 2
    return 0


def normalize_acquire_visual_providers(providers: list[str] | None) -> tuple[str, ...]:
    raw = providers or []
    normalized: list[str] = []
    for provider in raw:
        for item in str(provider).split(","):
            name = item.strip().lower().replace("_", "-")
            if name:
                normalized.append(name)
    return tuple(dict.fromkeys(normalized))



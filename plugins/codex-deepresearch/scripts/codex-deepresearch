    ingest_vision.add_argument(
        "--provider-mode",
        choices=("real", "fixture", "manual", "user_provided"),
        help=(
            "Provider mode for automated visual analysis. Real mode enables the "
            "Codex-native codex-interactive image worker and is required for "
            "API-backed providers."
        ),
    )
    ingest_vision.add_argument(
        "--allow-real-vlm",
        action="store_true",
        default=None,
        help=(
            "Permit external API-backed VLM calls for providers that require it. "

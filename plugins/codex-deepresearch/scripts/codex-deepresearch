#!/usr/bin/env python3
"""Developer runner for the Codex DeepResearch plugin scaffold."""

from __future__ import annotations

import argparse
import json
import shutil
import sys
from datetime import datetime, timezone
from pathlib import Path


PLUGIN_ROOT = Path(__file__).resolve().parents[1]
REPO_ROOT = PLUGIN_ROOT.parents[1]
PLUGIN_SRC = PLUGIN_ROOT / "src"
sys.path.insert(0, str(PLUGIN_SRC))

from deepresearch import ConfigResolutionError, resolve_config, validate_artifacts
from deepresearch.fetch_claims import FetchClaimsError, fetch_claims
from deepresearch.guardrails import GuardrailsError, enforce_guardrails
from deepresearch.manual_sources import ManualSourcesError, ingest_manual_sources
from deepresearch.mvp_smoke import DEFAULT_INVOKE, MvpSmokeError, run_mvp_smoke
from deepresearch.report_generation import ReportGenerationError, synthesize_report
from deepresearch.search_handoff import SearchHandoffError, ingest_run, prepare_run
from deepresearch.verification_matrix import VerificationMatrixError, verify_claims
from deepresearch.vision_adapter import VisionAdapterError, ingest_vision_observations

PLUGIN_NAME = "codex-deepresearch"
MARKETPLACE_PATH = REPO_ROOT / ".agents" / "plugins" / "marketplace.json"


def fail(message: str) -> None:
    print(f"ERROR: {message}", file=sys.stderr)
    raise SystemExit(1)


def read_json(path: Path) -> dict:
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except FileNotFoundError:
        fail(f"missing required file: {path.relative_to(REPO_ROOT)}")
    except json.JSONDecodeError as exc:
        fail(f"invalid JSON in {path.relative_to(REPO_ROOT)}: {exc}")


def resolve_repo_path(path_value: str) -> Path:
    path = Path(path_value)
    if path.is_absolute():
        return path
    return REPO_ROOT / path


def validate_manifest() -> dict:
    manifest_path = PLUGIN_ROOT / ".codex-plugin" / "plugin.json"
    manifest = read_json(manifest_path)
    if manifest.get("name") != PLUGIN_NAME:
        fail("plugin manifest name must be codex-deepresearch")
    if manifest.get("skills") != "./skills/":
        fail("plugin manifest must expose ./skills/")
    skill_path = PLUGIN_ROOT / "skills" / "deep-research" / "SKILL.md"
    if not skill_path.exists():
        fail("missing skills/deep-research/SKILL.md")
    return manifest


def validate_marketplace() -> dict:
    marketplace = read_json(MARKETPLACE_PATH)
    entries = marketplace.get("plugins")
    if not isinstance(entries, list):
        fail("marketplace plugins must be a list")
    matches = [entry for entry in entries if entry.get("name") == PLUGIN_NAME]
    if len(matches) != 1:
        fail("marketplace must contain exactly one codex-deepresearch entry")
    entry = matches[0]
    source = entry.get("source", {})
    if source.get("source") != "local":
        fail("marketplace source.source must be local")
    if source.get("path") != "./plugins/codex-deepresearch":
        fail("marketplace source.path must be ./plugins/codex-deepresearch")
    policy = entry.get("policy", {})
    if policy.get("installation") != "AVAILABLE":
        fail("marketplace policy.installation must be AVAILABLE")
    if policy.get("authentication") != "ON_INSTALL":
        fail("marketplace policy.authentication must be ON_INSTALL")
    if not entry.get("category"):
        fail("marketplace entry must include category")
    return marketplace


def create_run_directory(runs_dir: Path, invocation: str, install_preflight: bool) -> Path:
    now = datetime.now(timezone.utc)
    run_dir = runs_dir / f"smoke-{now.strftime('%Y%m%dT%H%M%SZ')}"
    suffix = 1
    while run_dir.exists():
        suffix += 1
        run_dir = runs_dir / f"smoke-{now.strftime('%Y%m%dT%H%M%SZ')}-{suffix}"
    run_dir.mkdir(parents=True)

    status = {
        "schema_version": "codex-deepresearch.smoke.v0",
        "status": "started",
        "created_at": now.isoformat().replace("+00:00", "Z"),
        "plugin": {
            "name": PLUGIN_NAME,
            "root": str(PLUGIN_ROOT.relative_to(REPO_ROOT)),
        },
        "invocation": invocation,
        "checks": {
            "manifest": "passed",
            "marketplace": "passed",
            "install_preflight": "passed" if install_preflight else "skipped",
        },
        "next_step": "M2+ issues will add execution modes, evidence, verification, and reports.",
    }
    (run_dir / "status.json").write_text(
        json.dumps(status, indent=2, sort_keys=True) + "\n",
        encoding="utf-8",
    )
    return run_dir


def run_smoke(args: argparse.Namespace) -> int:
    validate_manifest()
    marketplace = validate_marketplace()

    install_preflight = False
    if args.install:
        if shutil.which("codex") is None:
            fail("--install requires the codex CLI to be available on PATH")
        install_preflight = True

    runs_dir = Path(args.runs_dir)
    if not runs_dir.is_absolute():
        runs_dir = REPO_ROOT / runs_dir
    run_dir = create_run_directory(runs_dir, args.invoke, install_preflight)

    marketplace_name = marketplace.get("name", "codex-deepresearch-local")
    print("Codex DeepResearch smoke run started.")
    print(f"Run directory: {run_dir}")
    print(f"Invocation: {args.invoke}")
    if args.install:
        print(f"Install preflight: codex CLI found; marketplace={marketplace_name}")
    return 0


def run_resolve_config(args: argparse.Namespace) -> int:
    try:
        config = resolve_config(
            mode=args.mode,
            search_provider=args.search_provider,
            vlm_provider=args.vlm_provider,
            budget_preset=args.budget,
        )
    except ConfigResolutionError as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 2

    print(json.dumps(config.to_dict(), indent=2, sort_keys=True))
    return 0


def run_validate_evidence(args: argparse.Namespace) -> int:
    result = validate_artifacts(
        evidence_path=args.evidence,
        search_results_path=args.search_results,
        visual_observations_path=args.visual_observations,
        verifier_votes_path=args.verifier_votes,
    )
    print(json.dumps(result.to_dict(), indent=2, sort_keys=True))
    return 0 if result.valid else 2


def run_prepare(args: argparse.Namespace) -> int:
    try:
        result = prepare_run(
            question=args.question,
            runs_dir=resolve_repo_path(args.runs_dir),
            mode=args.mode,
            search_provider=args.search_provider,
            vlm_provider=args.vlm_provider,
            budget_preset=args.budget,
            freshness_requirement=args.freshness_requirement,
            route=None if args.route == "auto" else args.route,
            angles=args.angle,
            max_results=args.max_results,
        )
    except (ConfigResolutionError, SearchHandoffError) as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    return 0


def run_ingest(args: argparse.Namespace) -> int:
    try:
        result = ingest_run(
            run=args.run,
            runs_dir=resolve_repo_path(args.runs_dir),
        )
    except SearchHandoffError as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    if result["status"] in {"blocked_missing_search_handoff", "failed_validation"}:
        return 2
    validation = result.get("validation")
    if isinstance(validation, dict) and validation.get("valid") is False:
        return 2
    return 0


def run_fetch_claims(args: argparse.Namespace) -> int:
    try:
        result = fetch_claims(
            run=args.run,
            runs_dir=resolve_repo_path(args.runs_dir),
            timeout_seconds=args.timeout_seconds,
        )
    except (FetchClaimsError, SearchHandoffError, OSError) as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    if result["status"] in {"blocked_missing_fetch_queue", "failed_validation"}:
        return 2
    validation = result.get("validation")
    if isinstance(validation, dict) and validation.get("valid") is False:
        return 2
    return 0


def run_ingest_manual(args: argparse.Namespace) -> int:
    try:
        result = ingest_manual_sources(
            run=args.run,
            runs_dir=resolve_repo_path(args.runs_dir),
            question=args.question,
            urls=args.url,
            pdfs=args.pdf,
            image_urls=args.image_url,
            local_images=args.local_image,
            labels=args.label,
            budget_preset=args.budget,
            vlm_provider=args.vlm_provider,
        )
    except (ConfigResolutionError, ManualSourcesError, OSError) as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    validation = result.get("validation")
    if result["status"] == "failed_validation":
        return 2
    if isinstance(validation, dict) and validation.get("valid") is False:
        return 2
    return 0


def run_ingest_vision(args: argparse.Namespace) -> int:
    try:
        result = ingest_vision_observations(
            run=args.run,
            runs_dir=resolve_repo_path(args.runs_dir),
            provider=args.provider,
            observations=args.observations,
        )
    except (VisionAdapterError, SearchHandoffError, OSError) as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    if result["status"] in {"failed_normalization", "failed_validation"}:
        return 2
    validation = result.get("validation")
    if isinstance(validation, dict) and validation.get("valid") is False:
        return 2
    return 0


def run_verify_claims(args: argparse.Namespace) -> int:
    try:
        result = verify_claims(
            run=args.run,
            runs_dir=resolve_repo_path(args.runs_dir),
        )
    except (VerificationMatrixError, SearchHandoffError, OSError) as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    if result["status"] == "failed_validation":
        return 2
    validation = result.get("validation")
    if isinstance(validation, dict) and validation.get("valid") is False:
        return 2
    return 0


def run_enforce_guardrails(args: argparse.Namespace) -> int:
    try:
        result = enforce_guardrails(
            run=args.run,
            runs_dir=resolve_repo_path(args.runs_dir),
        )
    except (GuardrailsError, SearchHandoffError, OSError) as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    if result["status"] == "failed_validation":
        return 2
    validation = result.get("validation")
    if isinstance(validation, dict) and validation.get("valid") is False:
        return 2
    return 0


def run_synthesize(args: argparse.Namespace) -> int:
    try:
        result = synthesize_report(
            run=args.run,
            runs_dir=resolve_repo_path(args.runs_dir),
        )
    except (ReportGenerationError, SearchHandoffError, OSError) as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    if result["status"] != "completed":
        return 2
    return 0


def run_mvp_smoke_command(args: argparse.Namespace) -> int:
    try:
        result = run_mvp_smoke(
            runs_dir=resolve_repo_path(args.runs_dir),
            suite_id=args.suite_id,
            invoke=args.invoke,
            clean=args.clean,
            skip_codex_cli_install_check=args.skip_codex_cli_install_check,
        )
    except (MvpSmokeError, OSError, json.JSONDecodeError) as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        results_path = getattr(exc, "results_path", None)
        if results_path:
            print(f"Results: {results_path}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    return 0 if result["status"] == "passed" else 2


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="codex-deepresearch",
        description="Developer runner for the Codex DeepResearch plugin.",
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    smoke = subparsers.add_parser(
        "smoke",
        help="Validate the plugin scaffold and start a smoke run directory.",
    )
    smoke.add_argument(
        "--install",
        action="store_true",
        help="Also verify that local install/update prerequisites are available.",
    )
    smoke.add_argument(
        "--invoke",
        default="$deep-research: smoke test",
        help="Skill invocation text recorded in the smoke run status.",
    )
    smoke.add_argument(
        "--runs-dir",
        default="research-runs",
        help="Directory for smoke run artifacts, relative to the repo root by default.",
    )
    smoke.set_defaults(func=run_smoke)

    mvp_smoke = subparsers.add_parser(
        "mvp-smoke",
        help="Run the deterministic no-network MVP release-gate smoke suite.",
    )
    mvp_smoke.add_argument(
        "--invoke",
        default=DEFAULT_INVOKE,
        help="Skill invocation text recorded for the text-only invocation smoke.",
    )
    mvp_smoke.add_argument(
        "--runs-dir",
        default="research-runs",
        help="Directory for MVP smoke artifacts, relative to the repo root by default.",
    )
    mvp_smoke.add_argument(
        "--suite-id",
        default="mvp-smoke",
        help="Subdirectory name under --runs-dir for this smoke suite.",
    )
    mvp_smoke.add_argument(
        "--clean",
        action="store_true",
        help="Remove an existing suite directory before writing new artifacts.",
    )
    mvp_smoke.add_argument(
        "--skip-codex-cli-install-check",
        action="store_true",
        help=(
            "Skip the Codex CLI install/update capability check. The suite records "
            "the skip and does not mark plugin install/update smoke as passed."
        ),
    )
    mvp_smoke.set_defaults(func=run_mvp_smoke_command)

    resolve = subparsers.add_parser(
        "resolve-config",
        help="Normalize and validate runner execution mode configuration.",
    )
    resolve.add_argument(
        "--mode",
        required=True,
        help="Execution mode: codex-plugin, automated-cli, or manual-sources.",
    )
    resolve.add_argument(
        "--search-provider",
        help="Search provider override for the selected execution mode.",
    )
    resolve.add_argument(
        "--vlm-provider",
        help="VLM provider override for the selected execution mode.",
    )
    resolve.add_argument(
        "--budget",
        "--budget-preset",
        dest="budget",
        default="standard",
        help="Budget preset: quick, standard, deep, or exhaustive.",
    )
    resolve.set_defaults(func=run_resolve_config)

    validate = subparsers.add_parser(
        "validate-evidence",
        help="Validate evidence and adapter handoff artifacts.",
    )
    validate.add_argument(
        "--evidence",
        help="Path to evidence.json.",
    )
    validate.add_argument(
        "--search-results",
        help="Path to search_results.jsonl.",
    )
    validate.add_argument(
        "--visual-observations",
        help="Path to visual_observations.jsonl.",
    )
    validate.add_argument(
        "--verifier-votes",
        help="Path to verifier_votes.jsonl.",
    )
    validate.set_defaults(func=run_validate_evidence)

    prepare = subparsers.add_parser(
        "prepare",
        help="Create a Codex-native search handoff run directory.",
    )
    prepare.add_argument("question", help="Research question to hand off to Codex search.")
    prepare.add_argument(
        "--runs-dir",
        default="research-runs",
        help="Directory for run artifacts, relative to the repo root by default.",
    )
    prepare.add_argument(
        "--mode",
        default="codex-plugin",
        help="Execution mode. M4 supports codex-plugin.",
    )
    prepare.add_argument(
        "--search-provider",
        default="codex-native",
        help="Search provider. M4 supports codex-native.",
    )
    prepare.add_argument(
        "--vlm-provider",
        help="VLM provider override for the selected execution mode.",
    )
    prepare.add_argument(
        "--budget",
        "--budget-preset",
        dest="budget",
        default="standard",
        help="Budget preset: quick, standard, deep, or exhaustive.",
    )
    prepare.add_argument(
        "--freshness-requirement",
        default="any",
        help="Search freshness requirement: latest, recent, historical, or any.",
    )
    prepare.add_argument(
        "--route",
        default="auto",
        choices=("auto", "text_only", "visual_required", "visual_optional"),
        help="Search route override. Use auto to classify each planner angle.",
    )
    prepare.add_argument(
        "--angle",
        action="append",
        help="Planner angle to classify and hand off. Repeat for multiple angles.",
    )
    prepare.add_argument(
        "--max-results",
        type=int,
        default=8,
        help="Maximum expected SearchResult records for the generated task.",
    )
    prepare.set_defaults(func=run_prepare)

    ingest = subparsers.add_parser(
        "ingest",
        help="Ingest SearchResult records from a prepared run directory.",
    )
    ingest.add_argument(
        "--run",
        required=True,
        help="Run id under --runs-dir, or a direct path to a run directory.",
    )
    ingest.add_argument(
        "--runs-dir",
        default="research-runs",
        help="Directory for run artifacts, relative to the repo root by default.",
    )
    ingest.set_defaults(func=run_ingest)

    fetch_claims_parser = subparsers.add_parser(
        "fetch-claims",
        help="Fetch queued source bodies and extract low-confidence source-linked claims.",
    )
    fetch_claims_parser.add_argument(
        "--run",
        required=True,
        help="Run id under --runs-dir, or a direct path to a run directory.",
    )
    fetch_claims_parser.add_argument(
        "--runs-dir",
        default="research-runs",
        help="Directory for run artifacts, relative to the repo root by default.",
    )
    fetch_claims_parser.add_argument(
        "--timeout-seconds",
        type=float,
        default=10.0,
        help="Per-source fetch timeout for http(s), file, and data URLs.",
    )
    fetch_claims_parser.set_defaults(func=run_fetch_claims)

    ingest_manual = subparsers.add_parser(
        "ingest-manual",
        help="Record user-provided URLs and images without external search or fetch.",
    )
    ingest_manual.add_argument(
        "--run",
        help="Existing run id under --runs-dir, or a direct path to a run directory.",
    )
    ingest_manual.add_argument(
        "--question",
        help="Research question. Required when --run is omitted.",
    )
    ingest_manual.add_argument(
        "--runs-dir",
        default="research-runs",
        help="Directory for run artifacts, relative to the repo root by default.",
    )
    ingest_manual.add_argument(
        "--url",
        action="append",
        default=[],
        help="Manual http(s) page URL to record as a source. Repeatable.",
    )
    ingest_manual.add_argument(
        "--pdf",
        action="append",
        default=[],
        help="Manual PDF URL or existing local PDF file to record as a source. Repeatable.",
    )
    ingest_manual.add_argument(
        "--image-url",
        action="append",
        default=[],
        help="Manual http(s) image URL to record as a source and VisualEvidence. Repeatable.",
    )
    ingest_manual.add_argument(
        "--local-image",
        action="append",
        default=[],
        help="Existing local image file to copy into the run and record as VisualEvidence. Repeatable.",
    )
    ingest_manual.add_argument(
        "--label",
        action="append",
        default=[],
        help="Optional source title override, applied to manual inputs in option-group order. Repeatable.",
    )
    ingest_manual.add_argument(
        "--vlm-provider",
        help="VLM provider metadata for new manual runs.",
    )
    ingest_manual.add_argument(
        "--budget",
        "--budget-preset",
        dest="budget",
        default="standard",
        help="Budget preset for new manual runs: quick, standard, deep, or exhaustive.",
    )
    ingest_manual.set_defaults(func=run_ingest_manual)

    ingest_vision = subparsers.add_parser(
        "ingest-vision",
        help="Normalize visual observations into VisualEvidence records.",
    )
    ingest_vision.add_argument(
        "--run",
        required=True,
        help="Run id under --runs-dir, or a direct path to a run directory.",
    )
    ingest_vision.add_argument(
        "--runs-dir",
        default="research-runs",
        help="Directory for run artifacts, relative to the repo root by default.",
    )
    ingest_vision.add_argument(
        "--provider",
        required=True,
        choices=("codex-interactive", "openai-responses-vision", "manual-visual-review"),
        help="Visual analysis provider that produced the observation artifact.",
    )
    ingest_vision.add_argument(
        "--observations",
        help=(
            "JSONL observations artifact. Defaults to visual_observations.jsonl "
            "inside the run directory; an empty artifact records needs_visual_evidence "
            "for visual_required routes."
        ),
    )
    ingest_vision.set_defaults(func=run_ingest_vision)

    verify_claims_parser = subparsers.add_parser(
        "verify-claims",
        help="Apply deterministic route-specific verifier matrix rules to run claims.",
    )
    verify_claims_parser.add_argument(
        "--run",
        required=True,
        help="Run id under --runs-dir, or a direct path to a run directory.",
    )
    verify_claims_parser.add_argument(
        "--runs-dir",
        default="research-runs",
        help="Directory for run artifacts, relative to the repo root by default.",
    )
    verify_claims_parser.set_defaults(func=run_verify_claims)

    guardrails = subparsers.add_parser(
        "enforce-guardrails",
        help="Apply deterministic policy/privacy/copyright guardrails to run evidence.",
    )
    guardrails.add_argument(
        "--run",
        required=True,
        help="Run id under --runs-dir, or a direct path to a run directory.",
    )
    guardrails.add_argument(
        "--runs-dir",
        default="research-runs",
        help="Directory for run artifacts, relative to the repo root by default.",
    )
    guardrails.set_defaults(func=run_enforce_guardrails)

    synthesize = subparsers.add_parser(
        "synthesize",
        help="Generate report.md from supported, reviewed claims in one run.",
    )
    synthesize.add_argument(
        "--run",
        required=True,
        help="Run id under --runs-dir, or a direct path to a run directory.",
    )
    synthesize.add_argument(
        "--runs-dir",
        default="research-runs",
        help="Directory for run artifacts, relative to the repo root by default.",
    )
    synthesize.set_defaults(func=run_synthesize)
    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())

            include_excluded_caveats=args.include_excluded_caveats,
        )
    except (ReportExportError, ReportGenerationError, SearchHandoffError, OSError) as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    return 0



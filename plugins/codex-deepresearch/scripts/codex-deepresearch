        help="Optional image cap to apply before visual acquisition and VLM work starts.",
    )
    prepare.add_argument(
        "--max-subagents",
        type=int,
        help="Optional concurrent Codex subagent cap for the planned run.",
    )
    prepare.add_argument(
        "--max-agents",
        type=int,
        help="Optional concurrent runner-agent cap for the planned run.",
    )
    prepare.add_argument(
        "--max-cost-usd",
        type=float,
        help="Optional deterministic high-water cost cap in USD placeholder units.",
    )
    prepare.add_argument(
        "--codex-runner",
        default="codex-exec",
        choices=("codex-exec", "codex-sdk", "serial"),
        help="Automated runner mode used for orchestration overhead estimation.",
    )
    prepare.add_argument(
        "--confirm-budget",
        action="store_true",
        help="Confirm execution for deep and exhaustive budget presets.",
    )
    prepare.add_argument(
        "--allow-release-ineligible-materialization-for-tests",
        action="store_true",
        help=argparse.SUPPRESS,
    )
    add_release_validation_identity_args(prepare)
    prepare.set_defaults(func=run_prepare)

    ingest = subparsers.add_parser(
        "ingest",
        help="Ingest SearchResult records from a prepared run directory.",
    )
    ingest.add_argument(
        "--run",
        required=True,
        help="Run id under --runs-dir, or a direct path to a run directory.",
    )
    ingest.add_argument(
        "--runs-dir",
        default="research-runs",
        help="Directory for run artifacts, relative to the repo root by default.",
    )
    ingest.set_defaults(func=run_ingest)

    fetch_claims_parser = subparsers.add_parser(

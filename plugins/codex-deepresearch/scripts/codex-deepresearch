        results_path = getattr(exc, "results_path", None)
        if results_path:
            print(f"Results: {results_path}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    return 0 if result["status"] == "passed" else 2



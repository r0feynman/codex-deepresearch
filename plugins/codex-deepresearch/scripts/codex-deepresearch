def run_run_status(args: argparse.Namespace) -> int:
    try:
        run_dir = resolve_run_dir(args.run, runs_dir=resolve_repo_path(args.runs_dir))
        result = inspect_run_state(run_dir)
    except RunStepStateError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    except SearchHandoffError as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    return 0


def run_pause(args: argparse.Namespace) -> int:
    try:
        run_dir = resolve_run_dir(args.run, runs_dir=resolve_repo_path(args.runs_dir))
        result = pause_run(
            run_dir,
            reason=args.reason,
            requested_by=args.requested_by,
        )
    except SearchHandoffError as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    return 0


def run_resume(args: argparse.Namespace) -> int:
    try:
        run_dir = resolve_run_dir(args.run, runs_dir=resolve_repo_path(args.runs_dir))
        result = resume_run(
            run_dir,
            reason=args.reason,
            requested_by=args.requested_by,
        )
    except SearchHandoffError as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    return 0


def run_cancel(args: argparse.Namespace) -> int:
    try:
        run_dir = resolve_run_dir(args.run, runs_dir=resolve_repo_path(args.runs_dir))
        result = cancel_run(
            run_dir,
            reason=args.reason,
            requested_by=args.requested_by,
            cleanup_children=not args.no_cleanup_children,
        )
    except SearchHandoffError as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    return 0


def run_monitor_list(args: argparse.Namespace) -> int:
    result = list_run_monitors(resolve_repo_path(args.runs_dir))
    if args.json:
        print(json.dumps(result, indent=2, sort_keys=True))
    else:
        print(render_run_list(result))
    return 0


def run_monitor_detail(args: argparse.Namespace) -> int:
    try:
        run_dir = resolve_run_dir(args.run, runs_dir=resolve_repo_path(args.runs_dir))
    except SearchHandoffError as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 2

    result = inspect_run_monitor(run_dir)
    if args.json:
        print(json.dumps(result, indent=2, sort_keys=True))
    else:
        print(render_run_detail(result))
    return 0


def run_plan_parallel(args: argparse.Namespace) -> int:
    try:
        result = plan_research_tasks(
            run=args.run,
            runs_dir=resolve_repo_path(args.runs_dir),
            min_tasks=args.min_tasks,
            max_tasks=args.max_tasks,
            confirm_exhaustive=args.confirm_exhaustive,
            max_cost_usd=args.max_cost_usd,
        )
    except (ParallelOrchestrationError, SearchHandoffError, OSError) as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    return 0


def run_orchestrate_parallel(args: argparse.Namespace) -> int:
    try:
        result = run_parallel_orchestration(
            run=args.run,
            runs_dir=resolve_repo_path(args.runs_dir),
            adapter_name=args.adapter,
            min_tasks=args.min_tasks,
            max_tasks=args.max_tasks,
            retry_failed=args.retry_failed,
            allow_degraded=not args.no_degrade,
            confirm_exhaustive=args.confirm_exhaustive,
            max_cost_usd=args.max_cost_usd,
            codex_exec_timeout_seconds=args.codex_exec_timeout_seconds,
        )
    except (AdapterUnavailable, ParallelOrchestrationError, SearchHandoffError, OSError) as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    if result.get("ok") is False:
        return 2
    validation = result.get("merge", {}).get("validation")
    if isinstance(validation, dict) and validation.get("valid") is False:
        return 2
    return 0


def run_mvp_smoke_command(args: argparse.Namespace) -> int:
    try:
        result = run_mvp_smoke(
            runs_dir=resolve_repo_path(args.runs_dir),
            suite_id=args.suite_id,
            invoke=args.invoke,
            clean=args.clean,
            skip_codex_cli_install_check=args.skip_codex_cli_install_check,
        )
    except (MvpSmokeError, OSError, json.JSONDecodeError) as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        results_path = getattr(exc, "results_path", None)
        if results_path:
            print(f"Results: {results_path}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    return 0 if result["status"] == "passed" else 2


def run_fresh_session_e2e_command(args: argparse.Namespace) -> int:
    try:
        result = run_fresh_session_e2e(
            runs_dir=resolve_repo_path(args.runs_dir),
            suite_id=args.suite_id,
            invocation=args.invoke,
            clean=args.clean,
            real_codex_exec=args.real_codex_exec,
            runner_path=Path(__file__).resolve(),
            scenario_timeout_seconds=args.scenario_timeout_seconds,
        )
    except (FreshSessionE2EError, OSError, json.JSONDecodeError) as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        results_path = getattr(exc, "results_path", None)
        if results_path:
            print(f"Results: {results_path}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    return 0 if result["status"] == "passed" else 2


def run_automated_visual_e2e_command(args: argparse.Namespace) -> int:
    scenario_runs = {}
    try:
        for value in args.scenario_run or []:
            scenario_id, run_dir = parse_scenario_run(value)
            scenario_runs[scenario_id] = run_dir
        result = run_automated_visual_e2e(
            runs_dir=resolve_repo_path(args.runs_dir),
            suite_id=args.suite_id,
            clean=args.clean,
            scenario_runs=scenario_runs,
            min_image_candidates=args.min_image_candidates,
            min_vlm_images=args.min_vlm_images,
        )
    except (AutomatedVisualE2EError, OSError, json.JSONDecodeError) as exc:
        results_path = getattr(exc, "results_path", None)
        if results_path and Path(results_path).is_file():
            payload = json.loads(Path(results_path).read_text(encoding="utf-8"))
            print(json.dumps(payload, indent=2, sort_keys=True))
            if payload.get("status") == "blocked" and args.allow_blocked:
                return 0
            return 2
        print(f"ERROR: {exc}", file=sys.stderr)
        results_path = getattr(exc, "results_path", None)
        if results_path:
            print(f"Results: {results_path}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    return 0 if result["status"] == "passed" else 2


def run_fresh_session_visual_e2e_command(args: argparse.Namespace) -> int:

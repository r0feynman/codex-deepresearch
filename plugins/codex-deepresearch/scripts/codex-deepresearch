        print(f"ERROR: {exc}", file=sys.stderr)
        if results_path:
            print(f"Results: {results_path}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    return 0 if result["status"] == "passed" else 2


def run_public_beta_validation_command(args: argparse.Namespace) -> int:
    prompt_runs = {}
    gate_results = {}
    try:
        for value in args.run or []:
            prompt_id, run_dir = parse_public_beta_run(value)
            prompt_runs[prompt_id] = resolve_repo_path(str(run_dir))
        for value in args.gate_result or []:
            gate_id, results_path = parse_public_beta_gate_result(value)
            gate_results[gate_id] = resolve_repo_path(str(results_path))
        result = run_public_beta_validation(
            runs_dir=resolve_repo_path(args.runs_dir),
            suite_id=args.suite_id,
            clean=args.clean,
            prompt_manifest=resolve_repo_path(args.prompt_manifest),
            prompt_runs=prompt_runs,
            gate_results=gate_results,
            completion_mode=normalize_public_beta_completion_mode(args.completion_mode),
            manual_audit_manifest=resolve_repo_path(args.manual_audit_manifest)
            if args.manual_audit_manifest
            else None,
            require_manual_trace_audits=args.require_manual_trace_audits,
        )
    except (PublicBetaValidationError, OSError, json.JSONDecodeError) as exc:
        results_path = getattr(exc, "results_path", None)
        if results_path and Path(results_path).is_file():
            payload = json.loads(Path(results_path).read_text(encoding="utf-8"))
            print(json.dumps(payload, indent=2, sort_keys=True))
            if payload.get("status") == "blocked" and args.allow_blocked:
                return 0
            return 2
        print(f"ERROR: {exc}", file=sys.stderr)
        if results_path:
            print(f"Results: {results_path}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    return 0 if result["status"] == "passed" else 2


def run_semantic_release_validation_command(args: argparse.Namespace) -> int:
    regression_runs = {}
    public_beta_runs = {}
    holdout_runs = {}
    try:
        for value in args.regression_run or []:
            prompt_id, run_dir = parse_public_beta_run(value)
            regression_runs[prompt_id] = resolve_repo_path(str(run_dir))
        for value in args.public_beta_run or []:
            prompt_id, run_dir = parse_public_beta_run(value)
            public_beta_runs[prompt_id] = resolve_repo_path(str(run_dir))
        for value in args.holdout_run or []:
            prompt_id, run_dir = parse_public_beta_run(value)
            holdout_runs[prompt_id] = resolve_repo_path(str(run_dir))
        result = run_semantic_release_validation(
            runs_dir=resolve_repo_path(args.runs_dir),
            suite_id=args.suite_id,
            clean=args.clean,
            semantic_regression_manifest=resolve_repo_path(args.semantic_regression_manifest),
            public_beta_semantic_manifest=resolve_repo_path(
                args.public_beta_semantic_manifest
            ),
            blind_holdout_manifest=resolve_repo_path(args.blind_holdout_manifest),
            manual_audit_manifest=resolve_repo_path(args.manual_audit_manifest)
            if args.manual_audit_manifest
            else None,
            semantic_regression_runs=regression_runs,
            public_beta_semantic_runs=public_beta_runs,
            blind_holdout_runs=holdout_runs,
        )
    except (PublicBetaValidationError, OSError, json.JSONDecodeError) as exc:
        results_path = getattr(exc, "results_path", None)
        if results_path and Path(results_path).is_file():
            payload = json.loads(Path(results_path).read_text(encoding="utf-8"))
            print(json.dumps(payload, indent=2, sort_keys=True))
            if payload.get("status") in {"blocked", "failed"} and args.allow_blocked:
                return 0
            return 2
        print(f"ERROR: {exc}", file=sys.stderr)
        if results_path:
            print(f"Results: {results_path}", file=sys.stderr)
        return 2

    print(json.dumps(result, indent=2, sort_keys=True))
    return 0 if result["status"] == "passed" else 2


def run_semantic_release_run_inputs_command(args: argparse.Namespace) -> int:
    try:
        regression_manifest = load_semantic_regression_manifest(
            resolve_repo_path(args.semantic_regression_manifest)
        )
        public_manifest = load_public_beta_semantic_manifest(
            resolve_repo_path(args.public_beta_semantic_manifest)
        )
        holdout_manifest = load_blind_holdout_manifest(
            resolve_repo_path(args.blind_holdout_manifest),
            known_manifests=[regression_manifest, public_manifest],
        )
    except (PublicBetaValidationError, OSError, json.JSONDecodeError) as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 2

    if holdout_manifest.get("release_gate_ready") is not True:
        failures = holdout_manifest.get("failures") or ["holdout_release_gate_not_ready"]
        print(
            "ERROR: blind holdout manifest is not release-ready: "
            + "; ".join(str(failure) for failure in failures),
            file=sys.stderr,
        )
        return 2

    prompt_sets = [
        ("semantic_regression", "--regression-run", regression_manifest),
        ("public_beta_semantic", "--public-beta-run", public_manifest),
        ("blind_holdout", "--holdout-run", holdout_manifest),
    ]
    prepare_commands = []
    validation_args = []
    semantic_timeout_env = {
        "CODEX_DEEPRESEARCH_SEMANTIC_PLANNER_TIMEOUT_SECONDS": str(
            args.semantic_adapter_timeout_seconds
        ),
        "CODEX_DEEPRESEARCH_SEMANTIC_ORACLE_TIMEOUT_SECONDS": str(
            args.semantic_adapter_timeout_seconds
        ),
        "CODEX_DEEPRESEARCH_SEMANTIC_REVIEWER_TIMEOUT_SECONDS": str(
            args.semantic_adapter_timeout_seconds
        ),
    }
    for suite_label, validation_flag, manifest in prompt_sets:
        for prompt in manifest["prompts"]:
            prompt_id = prompt["id"]
            fragment_id = _manifest_oracle_fragment_id(str(prompt["oracle_path"]))
            base_command = [
                str(Path(__file__).resolve()),
                "prepare" if args.mode == "prepare" else "invoke",
            ]
            if args.mode == "invoke":
                base_command.extend([f"$deep-research: {prompt['prompt']}"])
            else:
                base_command.append(prompt["prompt"])
            base_command.extend(
                [
                    "--runs-dir",
                    args.runs_dir,
                    "--route",
                    prompt["route"],
                    "--prompt-id",
                    prompt_id,
                    "--suite-id",
                    args.suite_id,
                    "--prompt-hash",
                    prompt["prompt_hash"],
                    "--original-question",
                    prompt["prompt"],
                    "--manifest-oracle-hash",
                    prompt["oracle_hash"],
                    "--manifest-oracle-path",
                    prompt["oracle_path"],
                    "--manifest-oracle-fragment-id",
                    fragment_id,
                ]
            )
            if args.mode == "invoke":
                base_command.extend(
                    [
                        "--codex-exec-timeout-seconds",
                        str(args.codex_exec_timeout_seconds),
                    ]
                )
            command = [
                "env",
                *[
                    f"{name}={value}"
                    for name, value in sorted(semantic_timeout_env.items())
                ],
                *base_command,
            ]
            prepare_commands.append(
                {
                    "suite": suite_label,
                    "prompt_id": prompt_id,
                    "mode": args.mode,
                    "command": command,
                    "base_command": base_command,
                    "environment": semantic_timeout_env,
                    "semantic_adapter_timeout_seconds": args.semantic_adapter_timeout_seconds,
                    "codex_exec_timeout_seconds": (
                        args.codex_exec_timeout_seconds if args.mode == "invoke" else None
                    ),
                    "shell": shlex.join(command),
                    "semantic_release_validation_input": {
                        "flag": validation_flag,
                        "value": f"{prompt_id}=<run_dir>",
                    },
                }
            )
            validation_args.extend([validation_flag, f"{prompt_id}=<run_dir>"])
    validation_command = [
        str(Path(__file__).resolve()),
        "semantic-release-validation",
        "--runs-dir",
        args.runs_dir,
        "--suite-id",
        args.suite_id,
        "--semantic-regression-manifest",
        args.semantic_regression_manifest,
        "--public-beta-semantic-manifest",
        args.public_beta_semantic_manifest,
        "--blind-holdout-manifest",
        args.blind_holdout_manifest,
        *validation_args,
    ]
    if args.manual_audit_manifest:
        validation_command.extend(["--manual-audit-manifest", args.manual_audit_manifest])
    payload = {
        "schema_version": "codex-deepresearch.semantic-release-run-inputs.v0",
        "suite_id": args.suite_id,
        "mode": args.mode,
        "runs_dir": args.runs_dir,
        "semantic_adapter_timeout_seconds": args.semantic_adapter_timeout_seconds,
        "codex_exec_timeout_seconds": (
            args.codex_exec_timeout_seconds if args.mode == "invoke" else None
        ),
        "prepare_commands": prepare_commands,
        "semantic_release_validation_command": validation_command,
        "semantic_release_validation_shell": shlex.join(validation_command),
    }
    print(json.dumps(payload, indent=2, sort_keys=True))
    return 0


def _manifest_oracle_fragment_id(oracle_path: str) -> str:
    return oracle_path.split("#", 1)[1].strip() if "#" in oracle_path else ""


def add_release_validation_identity_args(parser: argparse.ArgumentParser) -> None:
    parser.add_argument(
        "--prompt-id",
        help=(
            "Public Beta release-validation prompt id. When set, --suite-id is "
            "also required and identity is written before child execution starts."
        ),
    )
    parser.add_argument(
        "--suite-id",
        help="Public Beta validation suite id for release-validation artifacts.",
    )
    parser.add_argument(
        "--prompt-hash",
        help=(
            "Optional canonical Public Beta prompt hash. If omitted, the hash is "
            "computed from --original-question or the normalized invocation question."
        ),
    )
    parser.add_argument(
        "--original-question",
        help=(
            "Optional manifest prompt text used for prompt_hash binding. Defaults "
            "to the normalized invocation question."
        ),
    )
    parser.add_argument(
        "--manifest-oracle-hash",
        help="Release manifest oracle fragment sha256 to bind before child execution.",
    )
    parser.add_argument(
        "--manifest-oracle-path",
        help=(
            "Release manifest oracle path, usually relative to the manifest and "
            "including a #fragment id."
        ),
    )
    parser.add_argument(
        "--manifest-oracle-fragment-id",
        help=(
            "Optional oracle fragment id. If omitted, it is derived from "
            "--manifest-oracle-path when that path includes a #fragment."
        ),
    )


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="codex-deepresearch",
        description="Developer runner for the Codex DeepResearch plugin.",
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    smoke = subparsers.add_parser(
        "smoke",
        help="Validate the plugin scaffold and start a smoke run directory.",
    )
    smoke.add_argument(
        "--install",
        action="store_true",
        help="Also verify that local install/update prerequisites are available.",
    )
    smoke.add_argument(
        "--invoke",
        default="$deep-research: smoke test",
        help="Skill invocation text recorded in the smoke run status.",
    )
    smoke.add_argument(
        "--runs-dir",
        default="research-runs",
        help="Directory for smoke run artifacts, relative to the repo root by default.",
    )
    smoke.set_defaults(func=run_smoke)

    mvp_smoke = subparsers.add_parser(
        "mvp-smoke",
        help="Run the deterministic no-network MVP release-gate smoke suite.",
    )
    mvp_smoke.add_argument(
        "--invoke",
        default=DEFAULT_INVOKE,
        help="Skill invocation text recorded for the text-only invocation smoke.",
    )
    mvp_smoke.add_argument(
        "--runs-dir",
        default="research-runs",
        help="Directory for MVP smoke artifacts, relative to the repo root by default.",
    )
    mvp_smoke.add_argument(
        "--suite-id",
        default="mvp-smoke",
        help="Subdirectory name under --runs-dir for this smoke suite.",
    )
    mvp_smoke.add_argument(
        "--clean",
        action="store_true",
        help="Remove an existing suite directory before writing new artifacts.",
    )
    mvp_smoke.add_argument(
        "--skip-codex-cli-install-check",
        action="store_true",
        help=(
            "Skip the Codex CLI install/update capability check. The suite records "
            "the skip and does not mark plugin install/update smoke as passed."
        ),
    )
    mvp_smoke.set_defaults(func=run_mvp_smoke_command)

    fresh_session = subparsers.add_parser(
        "fresh-session-e2e",
        help="Run the scripted fresh-session $deep-research artifact handoff gate.",
    )
    fresh_session.add_argument(
        "--invoke",
        default=DEFAULT_FRESH_SESSION_INVOKE,
        help="Text-heavy $deep-research invocation captured in the scripted transcript.",
    )
    fresh_session.add_argument(
        "--runs-dir",
        default="research-runs",
        help="Directory for fresh-session gate artifacts, relative to the repo root by default.",
    )
    fresh_session.add_argument(
        "--suite-id",
        default="fresh-session-e2e",
        help="Subdirectory name under --runs-dir for this gate.",
    )
    fresh_session.add_argument(
        "--clean",
        action="store_true",
        help="Remove an existing suite directory before writing new artifacts.",
    )
    fresh_session.add_argument(
        "--real-codex-exec",
        default="skip",
        choices=("auto", "require", "skip"),
        help=(
            "How to handle the real codex-exec scenario: skip records a public-safe "
            "blocked diagnostic, auto attempts it when "
            "Codex CLI is available, require fails unless real execution is available, "
            "and every launched scenario is bounded by --scenario-timeout-seconds."
        ),
    )
    fresh_session.add_argument(
        "--scenario-timeout-seconds",
        type=float,
        default=DEFAULT_SCENARIO_TIMEOUT_SECONDS,
        help="Per-scenario subprocess timeout for fixture, serial, auto, and require paths.",
    )
    fresh_session.set_defaults(func=run_fresh_session_e2e_command)

    automated_visual = subparsers.add_parser(
        "automated-visual-e2e",
        help="Run the automated-cli real-provider visual E2E release gate.",
    )
    automated_visual.add_argument(
        "--runs-dir",
        default="research-runs",
        help="Directory for automated visual gate artifacts, relative to the repo root by default.",
    )
    automated_visual.add_argument(
        "--suite-id",
        default="automated-visual-e2e",
        help="Subdirectory name under --runs-dir for this gate.",
    )
    automated_visual.add_argument(
        "--clean",
        action="store_true",
        help="Remove an existing suite directory before writing new artifacts.",
    )
    automated_visual.add_argument(
        "--scenario-run",
        action="append",
        help=(
            "Existing real-provider scenario run in the form scenario_id=run_dir. "
            "Repeat for product_image_discovery, ui_screenshot_comparison, "
            "public_chart_report_visual_extraction, and public_pdf_paper_figure_extraction. "
            "When omitted, the gate writes blocked diagnostics and makes no provider calls."
        ),
    )
    automated_visual.add_argument(
        "--min-image-candidates",
        type=int,
        default=10,
        help="Minimum real candidates required for the image-centric scenario.",
    )
    automated_visual.add_argument(
        "--min-vlm-images",
        type=int,
        default=3,
        help="Minimum real images openai-responses-vision must analyze in accepted runs.",
    )
    automated_visual.add_argument(
        "--allow-blocked",
        action="store_true",
        help=(
            "Exit zero when the gate records explicit blocked diagnostics, useful for "
            "credential-free environment checks. Passed release gates still require "
            "all real scenario runs."
        ),
    )
    automated_visual.set_defaults(func=run_automated_visual_e2e_command)

    fresh_session_visual = subparsers.add_parser(
        "fresh-session-visual-e2e",
        help="Run the scripted fresh-session visual release-gate harness.",
    )
    fresh_session_visual.add_argument(
        "--invoke",
        default=DEFAULT_FRESH_SESSION_VISUAL_INVOKE,
        help="Visual-required $deep-research invocation captured in the scripted transcript.",
    )
    fresh_session_visual.add_argument(
        "--runs-dir",
        default="research-runs",

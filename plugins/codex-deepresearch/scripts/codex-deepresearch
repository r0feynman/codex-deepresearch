    reuse_evidence = subparsers.add_parser(
        "reuse-evidence",
        help="List claims currently eligible for downstream Codex reuse or promotion.",
    )
    reuse_evidence.add_argument(
        "--run",
        required=True,
        help="Run id under --runs-dir, or a direct path to a run directory.",

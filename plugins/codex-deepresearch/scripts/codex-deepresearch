    )
    acquire_visual.add_argument(
        "--provider",
        action="append",
        help=(
            "Visual provider. Repeatable or comma-separated. Defaults to "
            "local-page, local-image-fixture, local-screenshot-fixture, "
            "local-pdf-rasterizer. Use "
            "child-discovered-image-url to fetch/cache HTTP(S) image URLs already "
            "discovered by accepted real Codex child evidence, "
            "brave-image-search for the credential- and storage-confirmation-gated "
            "real web image search adapter. Use page-image-extractor alone to "
            "run the page image fetch/cache provider, or browser-screenshot for "
            "Playwright browser screenshots when available."
        ),
    )
    acquire_visual.add_argument(
        "--screenshot-mode",
